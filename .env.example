# .env.example — переменные окружения (плейсхолдеры).
# Скопируйте в .env и подставьте реальные значения. .env в git НЕ коммитится.
# Переменные окружения имеют приоритет над data/aparser_monitor.config.json
# (см. env_map в aparser_monitor.py::load_config).

# --- A-Parser API (версия Enterprise) ---
APARSER_URL=http://127.0.0.1:9091/API
APARSER_PASSWORD=ВАШ_ПАРОЛЬ_ОТ_API

# --- Telegram-уведомления ---
TELEGRAM_BOT_TOKEN=123456:ABC-ВАШ_ТОКЕН_БОТА
TELEGRAM_CHAT_ID=ВАШ_CHAT_ID

# --- Пороги алертов (опционально; иначе берутся из конфига/дефолтов) ---
APARSER_ERROR_THRESHOLD=0.5
APARSER_COOLDOWN_HOURS=8
